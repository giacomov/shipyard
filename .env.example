POSTGRES_DB=shipyard
POSTGRES_USER=shipyard
POSTGRES_PASSWORD=shipyard_secret
DATABASE_URL=postgresql+asyncpg://shipyard:shipyard_secret@db:5432/shipyard
JWT_SECRET=change-me-in-production-use-a-long-random-string
# JSON array of seed users: [{"email":"...","display_name":"...","password":"..."}]
MOCK_USERS=[{"email":"alice@example.com","display_name":"Alice","password":"password123"},{"email":"bob@example.com","display_name":"Bob","password":"password123"}]
